rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.firebase.sign_in_provider == 'google.com');
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == 'djignaci1@gmail.com';
    }

    function isRoleAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN';
    }

    function isRoleFinance() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'FINANCE';
    }

    function isAdmin() {
      return isSuperAdmin() || isRoleAdmin();
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Match Rules ---

    // Users collection
    match /users/{userId} {
      // allow get is for single doc access (e.g. useAuth)
      allow get: if isSignedIn(); 
      // allow list is for admin analytics
      allow list: if isAdmin();
      // Only the user or an admin can write
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Documents
    match /documents/{docId} {
      // Students can read their own, Admins can read all
      allow read: if isAdmin() || (isSignedIn() && existing().studentId == request.auth.uid);
      // Students can create their own
      allow create: if isSignedIn() && incoming().studentId == request.auth.uid;
      // Admins can verify, Students can potentially re-upload (update)
      allow update: if isAdmin() || (isSignedIn() && existing().studentId == request.auth.uid);
      // List rules for queries
      allow list: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Appointments (Photo Sessions)
    match /appointments/{apptId} {
      allow read: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && incoming().studentId == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && existing().studentId == request.auth.uid);
      allow delete: if isAdmin() || (isSignedIn() && existing().studentId == request.auth.uid);
    }

    // Announcements
    match /announcements/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Notifications
    match /notifications/{notifId} {
      allow read, update, delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      // System sends notifications (client can addDoc for demo purposes if needed, though usually server-side)
      allow create: if isSignedIn(); 
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Batches
    match /batches/{batchId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Receipts
    match /receipts/{receiptId} {
      allow read: if isAdmin() || isRoleFinance();
      allow write: if isAdmin() || isRoleFinance();
    }

    // Audit Logs
    match /audit_logs/{logId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
      allow list: if isAdmin();
    }

    // Settings
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
