rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.firebase.sign_in_provider == 'google.com');
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == 'djignaci1@gmail.com';
    }

    function isRole(role) {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'STUDENT') == role;
    }

    function isAdmin() {
      return isSuperAdmin() || isRole('ADMIN');
    }

    function isFinance() {
      return isRole('FINANCE');
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Match Rules ---

    // Users collection
    match /users/{userId} {
      allow get: if isSignedIn(); 
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Documents
    match /documents/{docId} {
      allow read: if isAdmin() || (isFinance() && (existing().type == 'RECEIPT' || existing().type == 'PAYMENT')) || isOwner(existing().studentId);
      allow create: if isSignedIn() && incoming().studentId == request.auth.uid;
      allow update: if isAdmin() || (isFinance() && existing().type == 'RECEIPT') || isOwner(existing().studentId);
      allow list: if isAdmin() || (isFinance() && (resource.data.type == 'RECEIPT' || resource.data.type == 'PAYMENT')) || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Appointments (Photo Sessions)
    match /appointments/{apptId} {
      allow read: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && incoming().studentId == request.auth.uid;
      allow update: if isAdmin() || isOwner(existing().studentId);
      allow delete: if isAdmin() || isOwner(existing().studentId);
    }

    // Announcements
    match /announcements/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Notifications
    match /notifications/{notifId} {
      allow read, update, delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      // System sends notifications (client can addDoc for demo purposes if needed, though usually server-side)
      allow create: if isSignedIn(); 
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Batches
    match /batches/{batchId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Receipts
    match /receipts/{receiptId} {
      allow read, list: if isAdmin() || isFinance();
      allow write: if isAdmin() || isFinance();
    }

    // Audit Logs
    match /audit_logs/{logId} {
      allow create: if isSignedIn();
      allow read, list: if isAdmin() || isFinance();
    }

    // Settings
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
